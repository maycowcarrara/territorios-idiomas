rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function meuEmail() {
      return request.auth.token.email.lower();
    }

    function getDadosUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(meuEmail())).data;
    }

    function isAdmin() {
      return estaLogado() &&
             exists(/databases/$(database)/documents/usuarios/$(meuEmail())) &&
             getDadosUsuario().role == 'admin';
    }

    function isAprovado() {
      return estaLogado() &&
             exists(/databases/$(database)/documents/usuarios/$(meuEmail())) &&
             (getDadosUsuario().role == 'admin' || getDadosUsuario().role == 'comum');
    }

    function isAguardando() {
      return estaLogado() &&
             exists(/databases/$(database)/documents/usuarios/$(meuEmail())) &&
             getDadosUsuario().role == 'aguardando';
    }

    function camposAlteradosApenas(camposPermitidos) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(camposPermitidos);
    }

    function camposOperacionaisTerritorio() {
      return [
        'quadras_feitas',
        'status',
        'historico',
        'ultimaConclusao',
        'ultimaAlteracao',
        'designadoPara',
        'designadoNome',
        'dataDesignacao',
        'designacaoId',
        'cicloAtual',
        'nome'
      ];
    }

    function camposOperacionaisContexto() {
      return [
        'quadras_feitas',
        'status',
        'historico',
        'ultimaConclusao',
        'ultimaAlteracao',
        'designadoPara',
        'designadoNome',
        'dataDesignacao',
        'designacaoId',
        'cicloAtual',
        'nome',
        'territorioBaseId',
        'territorioNumero',
        'contextoId',
        'contextoTipo',
        'contextoTitulo'
      ];
    }

    function camposNotasTerritorio() {
      return ['nome', 'notas_quadras', 'ultimaAlteracao'];
    }

    function camposNotaDocumento() {
      return [
        'quadraId',
        'texto',
        'autorEmail',
        'autorNome',
        'data',
        'editadoEm',
        'designacaoId',
        'territorioId',
        'contextoId'
      ];
    }

    function camposEndereco() {
      return [
        'codigo',
        'status',
        'grupoId',
        'grupoCodigo',
        'lat',
        'lng',
        'geohash',
        'endereco',
        'quantidadeEstrangeiros',
        'observacao',
        'origem',
        'importacaoId',
        'criadoEm',
        'criadoPor',
        'atualizadoEm',
        'atualizadoPor',
        'arquivadoEm',
        'arquivadoPor'
      ];
    }

    function camposGrupoEndereco() {
      return [
        'codigo',
        'nome',
        'status',
        'enderecoIds',
        'totalEnderecos',
        'totalEstrangeiros',
        'centro',
        'bounds',
        'designadoPara',
        'designadoNome',
        'dataDesignacao',
        'designacaoId',
        'cicloAtual',
        'enderecos_visitados',
        'historico',
        'ultimaConclusao',
        'ultimaAlteracao',
        'criadoEm',
        'criadoPor',
        'atualizadoEm',
        'atualizadoPor',
        'arquivadoEm',
        'arquivadoPor'
      ];
    }

    function textoOpcionalValido(valor, limite) {
      return valor == null || (valor is string && valor.size() <= limite);
    }

    function pontoMapaValido(valor) {
      return valor == null ||
             (
               valor is map &&
               valor.keys().hasOnly(['lat', 'lng']) &&
               valor.lat is number &&
               valor.lat >= -90 &&
               valor.lat <= 90 &&
               valor.lng is number &&
               valor.lng >= -180 &&
               valor.lng <= 180
             );
    }

    function boundsMapaValido(valor) {
      return valor == null ||
             (
               valor is map &&
               valor.keys().hasOnly(['minLat', 'minLng', 'maxLat', 'maxLng']) &&
               valor.minLat is number &&
               valor.minLat >= -90 &&
               valor.minLat <= 90 &&
               valor.maxLat is number &&
               valor.maxLat >= -90 &&
               valor.maxLat <= 90 &&
               valor.minLng is number &&
               valor.minLng >= -180 &&
               valor.minLng <= 180 &&
               valor.maxLng is number &&
               valor.maxLng >= -180 &&
               valor.maxLng <= 180
             );
    }

    function enderecoDocumentoValido() {
      return request.resource.data.keys().hasOnly(camposEndereco()) &&
             request.resource.data.codigo is string &&
             request.resource.data.codigo.matches('^E-[0-9]{4,}$') &&
             request.resource.data.status in ['ativo', 'arquivado'] &&
             (request.resource.data.grupoId == null || request.resource.data.grupoId is string) &&
             (request.resource.data.grupoCodigo == null || request.resource.data.grupoCodigo is string) &&
             request.resource.data.lat is number &&
             request.resource.data.lat >= -90 &&
             request.resource.data.lat <= 90 &&
             request.resource.data.lng is number &&
             request.resource.data.lng >= -180 &&
             request.resource.data.lng <= 180 &&
             textoOpcionalValido(request.resource.data.geohash, 24) &&
             request.resource.data.endereco is string &&
             request.resource.data.endereco.size() > 0 &&
             request.resource.data.endereco.size() <= 220 &&
             request.resource.data.quantidadeEstrangeiros is int &&
             request.resource.data.quantidadeEstrangeiros >= 0 &&
             request.resource.data.quantidadeEstrangeiros <= 99 &&
             textoOpcionalValido(request.resource.data.observacao, 2000) &&
             request.resource.data.origem in ['manual', 'json', 'importacao'] &&
             textoOpcionalValido(request.resource.data.importacaoId, 120) &&
             request.resource.data.criadoEm is timestamp &&
             request.resource.data.criadoPor is string &&
             request.resource.data.atualizadoEm is timestamp &&
             request.resource.data.atualizadoPor is string &&
             (request.resource.data.arquivadoEm == null || request.resource.data.arquivadoEm is timestamp) &&
             (request.resource.data.arquivadoPor == null || request.resource.data.arquivadoPor is string);
    }

    function podeCriarEndereco() {
      return isAdmin() &&
             enderecoDocumentoValido() &&
             request.resource.data.status == 'ativo' &&
             request.resource.data.origem == 'manual' &&
             request.resource.data.criadoPor == meuEmail() &&
             request.resource.data.atualizadoPor == meuEmail() &&
             request.resource.data.arquivadoEm == null &&
             request.resource.data.arquivadoPor == null;
    }

    function podeAtualizarEndereco() {
      return isAdmin() &&
             enderecoDocumentoValido() &&
             request.resource.data.codigo == resource.data.codigo &&
             request.resource.data.lat == resource.data.lat &&
             request.resource.data.lng == resource.data.lng &&
             request.resource.data.origem == resource.data.origem &&
             request.resource.data.importacaoId == resource.data.importacaoId &&
             request.resource.data.criadoEm == resource.data.criadoEm &&
             request.resource.data.criadoPor == resource.data.criadoPor &&
             request.resource.data.atualizadoPor == meuEmail();
    }

    function grupoEnderecoDocumentoValido() {
      return request.resource.data.keys().hasOnly(camposGrupoEndereco()) &&
             request.resource.data.codigo is string &&
             request.resource.data.codigo.matches('^T-[0-9]{3,}$') &&
             request.resource.data.nome is string &&
             request.resource.data.nome.size() > 0 &&
             request.resource.data.nome.size() <= 120 &&
             request.resource.data.status in ['ativo', 'arquivado', 'finalizado'] &&
             request.resource.data.enderecoIds is list &&
             request.resource.data.enderecoIds.size() <= 200 &&
             request.resource.data.totalEnderecos is int &&
             request.resource.data.totalEnderecos >= 0 &&
             request.resource.data.totalEnderecos <= 200 &&
             request.resource.data.totalEstrangeiros is int &&
             request.resource.data.totalEstrangeiros >= 0 &&
             request.resource.data.totalEstrangeiros <= 2000 &&
             pontoMapaValido(request.resource.data.centro) &&
             boundsMapaValido(request.resource.data.bounds) &&
             textoOpcionalValido(request.resource.data.designadoPara, 180) &&
             textoOpcionalValido(request.resource.data.designadoNome, 180) &&
             (request.resource.data.dataDesignacao == null || request.resource.data.dataDesignacao is timestamp) &&
             textoOpcionalValido(request.resource.data.designacaoId, 120) &&
             (request.resource.data.cicloAtual == null || request.resource.data.cicloAtual is map) &&
             request.resource.data.enderecos_visitados is list &&
             request.resource.data.historico is list &&
             (request.resource.data.ultimaConclusao == null || request.resource.data.ultimaConclusao is timestamp) &&
             (request.resource.data.ultimaAlteracao == null || request.resource.data.ultimaAlteracao is timestamp) &&
             request.resource.data.criadoEm is timestamp &&
             request.resource.data.criadoPor is string &&
             request.resource.data.atualizadoEm is timestamp &&
             request.resource.data.atualizadoPor is string &&
             (request.resource.data.arquivadoEm == null || request.resource.data.arquivadoEm is timestamp) &&
             (request.resource.data.arquivadoPor == null || request.resource.data.arquivadoPor is string);
    }

    function podeCriarGrupoEndereco() {
      return isAdmin() &&
             grupoEnderecoDocumentoValido() &&
             request.resource.data.status == 'ativo' &&
             request.resource.data.designadoPara == null &&
             request.resource.data.designadoNome == null &&
             request.resource.data.dataDesignacao == null &&
             request.resource.data.designacaoId == null &&
             request.resource.data.cicloAtual == null &&
             request.resource.data.enderecos_visitados.size() == 0 &&
             request.resource.data.historico.size() == 0 &&
             request.resource.data.criadoPor == meuEmail() &&
             request.resource.data.atualizadoPor == meuEmail() &&
             request.resource.data.arquivadoEm == null &&
             request.resource.data.arquivadoPor == null;
    }

    function podeAtualizarGrupoEndereco() {
      return isAdmin() &&
             grupoEnderecoDocumentoValido() &&
             request.resource.data.codigo == resource.data.codigo &&
             request.resource.data.criadoEm == resource.data.criadoEm &&
             request.resource.data.criadoPor == resource.data.criadoPor &&
             request.resource.data.atualizadoPor == meuEmail();
    }

    function docIdTerritorioContexto(contextoId, territorioBaseId) {
      return contextoId + '__' + territorioBaseId;
    }

    function existeEstadoTerritorioNoContexto(territorioBaseId, contextoId) {
      return contextoId == 'normal'
        ? exists(/databases/$(database)/documents/territorios/$(territorioBaseId))
        : exists(/databases/$(database)/documents/territorios_contexto/$(docIdTerritorioContexto(contextoId, territorioBaseId)));
    }

    function getEstadoTerritorioNoContexto(territorioBaseId, contextoId) {
      return contextoId == 'normal'
        ? get(/databases/$(database)/documents/territorios/$(territorioBaseId)).data
        : get(/databases/$(database)/documents/territorios_contexto/$(docIdTerritorioContexto(contextoId, territorioBaseId))).data;
    }

    function notaDocumentoValida() {
      return request.resource.data.keys().hasOnly(camposNotaDocumento()) &&
             request.resource.data.quadraId is string &&
             request.resource.data.texto is string &&
             request.resource.data.texto.size() <= 4000 &&
             request.resource.data.autorEmail is string &&
             request.resource.data.autorNome is string &&
             (request.resource.data.designacaoId == null || request.resource.data.designacaoId is string) &&
             request.resource.data.contextoId is string;
    }

    function mantemOuLimpaDesignacaoPropria() {
      return (
               request.resource.data.designadoPara == resource.data.designadoPara &&
               request.resource.data.designacaoId == resource.data.designacaoId
             ) ||
             (
               resource.data.designadoPara == meuEmail() &&
               request.resource.data.designadoPara == null &&
               request.resource.data.designadoNome == null &&
               request.resource.data.dataDesignacao == null &&
               request.resource.data.designacaoId == null &&
               request.resource.data.cicloAtual == null
             );
    }

    function mantemNomeSalvo() {
      return request.resource.data.nome == resource.data.nome ||
             resource.data.nome == null;
    }

    function podeAtualizarTerritorioDesignado() {
      return isAprovado() &&
             resource.data.designadoPara == meuEmail() &&
             camposAlteradosApenas(camposOperacionaisTerritorio()) &&
             mantemOuLimpaDesignacaoPropria() &&
             mantemNomeSalvo();
    }

    function podeAtualizarNotasTerritorio() {
      return isAdmin() &&
             camposAlteradosApenas(camposNotasTerritorio()) &&
             mantemNomeSalvo();
    }

    function podeAtualizarContextoDesignado() {
      return isAprovado() &&
             resource.data.designadoPara == meuEmail() &&
             camposAlteradosApenas(camposOperacionaisContexto()) &&
             mantemOuLimpaDesignacaoPropria() &&
             mantemNomeSalvo();
    }

    function podeCriarNotaTerritorio(territorioBaseId) {
      return isAprovado() &&
             notaDocumentoValida() &&
             request.resource.data.autorEmail == meuEmail() &&
             existeEstadoTerritorioNoContexto(territorioBaseId, request.resource.data.contextoId) &&
             getEstadoTerritorioNoContexto(territorioBaseId, request.resource.data.contextoId).designadoPara == meuEmail() &&
             getEstadoTerritorioNoContexto(territorioBaseId, request.resource.data.contextoId).designacaoId == request.resource.data.designacaoId;
    }

    function podeAtualizarNotaTerritorio(territorioBaseId) {
      return isAprovado() &&
             notaDocumentoValida() &&
             resource.data.autorEmail == meuEmail() &&
             request.resource.data.autorEmail == resource.data.autorEmail &&
             request.resource.data.contextoId == resource.data.contextoId &&
             request.resource.data.designacaoId == resource.data.designacaoId &&
             existeEstadoTerritorioNoContexto(territorioBaseId, resource.data.contextoId) &&
             getEstadoTerritorioNoContexto(territorioBaseId, resource.data.contextoId).designadoPara == meuEmail() &&
             getEstadoTerritorioNoContexto(territorioBaseId, resource.data.contextoId).designacaoId == resource.data.designacaoId;
    }

    function podeExcluirNotaTerritorio(territorioBaseId) {
      return isAprovado() &&
             resource.data.autorEmail == meuEmail() &&
             existeEstadoTerritorioNoContexto(territorioBaseId, resource.data.contextoId) &&
             getEstadoTerritorioNoContexto(territorioBaseId, resource.data.contextoId).designadoPara == meuEmail() &&
             getEstadoTerritorioNoContexto(territorioBaseId, resource.data.contextoId).designacaoId == resource.data.designacaoId;
    }

    function notificacaoValida() {
      return request.resource.data.keys().hasOnly([
               'para',
               'texto',
               'data',
               'lida',
               'lidaPor',
               'tipo',
               'origem',
               'tituloPush'
             ]) &&
             request.resource.data.para is string &&
             request.resource.data.texto is string &&
             request.resource.data.data is timestamp &&
             request.resource.data.lida is bool &&
             request.resource.data.texto.size() <= 2000;
    }

    function destinatarioAdminValido() {
      return request.resource.data.para is string &&
             exists(/databases/$(database)/documents/usuarios/$(request.resource.data.para.lower())) &&
             get(/databases/$(database)/documents/usuarios/$(request.resource.data.para.lower())).data.role == 'admin';
    }

    function podeCriarNotificacaoAdminSistemaDireta() {
      return estaLogado() &&
             notificacaoValida() &&
             (
               request.resource.data.para == 'ADMINS' ||
               destinatarioAdminValido()
             ) &&
             request.resource.data.origem == 'sistema' &&
             request.resource.data.lida == false &&
             !request.resource.data.keys().hasAny(['lidaPor']) &&
             (
               (isAguardando() && request.resource.data.tipo == 'cadastro') ||
               (isAprovado() &&
                 (
                   request.resource.data.tipo == 'conclusao' ||
                   request.resource.data.tipo == 'devolucao'
                 )
               )
             );
    }

    function atualizaLeituraNotificacao() {
      return estaLogado() &&
             camposAlteradosApenas(['lida']) &&
             resource.data.para == meuEmail() &&
             request.resource.data.lida is bool;
    }

    function atualizaLeituraNotificacaoAdmin() {
      return isAdmin() &&
             camposAlteradosApenas(['lidaPor']) &&
             resource.data.para == 'ADMINS' &&
             request.resource.data.lidaPor is list;
    }

    match /usuarios/{email} {
      allow read: if estaLogado() && (isAdmin() || meuEmail() == email);

      allow create: if isAdmin() || (
        estaLogado() &&
        meuEmail() == email &&
        request.resource.data.role == 'aguardando'
      );

      allow update: if isAdmin() || (
        estaLogado() &&
        meuEmail() == email &&
        request.resource.data.role == resource.data.role
      );

      allow delete: if isAdmin();
    }

    match /territorios/{territorio} {
      allow read: if isAprovado();
      allow update: if isAdmin() ||
                    podeAtualizarTerritorioDesignado() ||
                    podeAtualizarNotasTerritorio();
      allow create, delete: if isAdmin();

      match /notas/{notaId} {
        allow read: if isAprovado();
        allow create: if isAdmin() || podeCriarNotaTerritorio(territorio);
        allow update: if isAdmin() || podeAtualizarNotaTerritorio(territorio);
        allow delete: if isAdmin() || podeExcluirNotaTerritorio(territorio);
      }
    }

    match /territorios_contexto/{territorioContexto} {
      allow read: if isAprovado();
      allow create: if isAdmin();
      allow update: if isAdmin() || podeAtualizarContextoDesignado();
      allow delete: if isAdmin();
    }

    match /enderecos/{enderecoId} {
      allow read: if isAprovado();
      allow create: if podeCriarEndereco();
      allow update: if podeAtualizarEndereco();
      allow delete: if false;
    }

    match /grupos_enderecos/{grupoId} {
      allow read: if isAprovado();
      allow create: if podeCriarGrupoEndereco();
      allow update: if podeAtualizarGrupoEndereco();
      allow delete: if false;
    }

    match /contadores/{contadorId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() &&
                            contadorId == 'codigos' &&
                            request.resource.data.keys().hasOnly([
                              'proximoEndereco',
                              'proximoGrupoEndereco',
                              'atualizadoEm'
                            ]) &&
                            (!('proximoEndereco' in request.resource.data) ||
                              (request.resource.data.proximoEndereco is int &&
                               request.resource.data.proximoEndereco > 0)) &&
                            (!('proximoGrupoEndereco' in request.resource.data) ||
                              (request.resource.data.proximoGrupoEndereco is int &&
                               request.resource.data.proximoGrupoEndereco > 0)) &&
                            request.resource.data.atualizadoEm is timestamp;
      allow delete: if false;
    }

    match /configuracoes/{docId} {
      allow read: if isAprovado();
      allow create, update, delete: if isAdmin();
    }

    match /campanhas/{campanhaId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /notificacoes/{notificacao} {
      allow read: if estaLogado() && (
        resource.data.para == meuEmail() ||
        (resource.data.para == 'ADMINS' && isAdmin())
      );

      allow create: if isAdmin() || (
        estaLogado() &&
        notificacaoValida() &&
        request.resource.data.para == meuEmail()
      ) || podeCriarNotificacaoAdminSistemaDireta();

      allow update: if atualizaLeituraNotificacao() ||
                    atualizaLeituraNotificacaoAdmin();

      allow delete: if estaLogado() && (
        resource.data.para == meuEmail()
      );
    }
  }
}
